<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="navbar-brand">BlogHub</a>
      <div class="nav-links">
        <a href="/login" class="nav-link">Login</a>
        <a href="/register" class="nav-link">Register</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="auth-wrapper">
      <div class="auth-box">
        <h1>Welcome Back</h1>
        <p class="subtitle">Sign in to your account</p>
        
        <% if (typeof message !== 'undefined' && message) { %>
          <div class="alert alert-danger">
            <%= message %>
          </div>
        <% } %>

        <form action="/login" method="post" class="auth-form">
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com">
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Enter your password">
          </div>

          <button type="submit" class="btn btn-primary btn-lg" style="width: 100%; margin-top: 0.5rem;">Sign In</button>
        </form>

        <p class="auth-link">Don't have an account? <a href="/register">Create one now</a></p>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>&copy; 2026 BlogHub. All rights reserved.</p>
  </footer>
</body>
</html>
