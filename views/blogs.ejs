<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Blogs</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="navbar-brand">BlogHub</a>
      <div class="nav-links">
        <% if (typeof user !== 'undefined' && user) { %>
          <span class="user-greeting"><%= user.fullName %></span>
          <a href="/logout" class="nav-link logout">Logout</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="blogs-header">
      <div>
        <h1>All Blogs</h1>
        <p class="subtitle">Discover professional insights and stories</p>
      </div>
      <a href="/blogs/new" class="btn btn-primary btn-lg">Create Blog Post</a>
    </div>

    <% if (typeof blogs !== 'undefined' && blogs.length > 0) { %>
      <div class="blogs-list">
        <% blogs.forEach(blog => { %>
          <div class="blog-card">
            <% if (blog.blogImage) { %>
              <div class="blog-image-container">
                <img src="<%= blog.blogImage %>" alt="Blog thumbnail" class="blog-image">
              </div>
            <% } else { %>
              <div class="blog-image-placeholder">
                ■
              </div>
            <% } %>
            
            <div class="blog-meta">
              <h3 class="blog-title"><%= blog.blogContent.substring(0, 60) %>...</h3>
              <div class="blog-info">
                <span class="blog-author">By <%= blog.authorName %></span>
                <span class="blog-date"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
              </div>
              <% if (blog.updatedAt && blog.updatedAt > blog.createdAt) { %>
                <p class="blog-updated">Last updated: <%= new Date(blog.updatedAt).toLocaleDateString() %></p>
              <% } %>
            </div>
            
            <div class="blog-content">
              <p><%= blog.blogContent.substring(0, 150) %>...</p>
            </div>
            
            <div class="blog-actions">
              <% if (typeof user !== 'undefined' && user && user._id.toString() === blog.author._id.toString()) { %>
                <a href="/blogs/<%= blog._id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
                <a href="/blogs/<%= blog._id %>/delete" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this blog?');">Delete</a>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">□</div>
        <p>No blogs published yet. <a href="/blogs/new" class="link-primary">Create your first blog post</a></p>
      </div>
    <% } %>
  </div>

  <footer class="footer">
    <p>&copy; 2026 BlogHub. All rights reserved.</p>
  </footer>
</body>
</html>
